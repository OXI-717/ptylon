# Local verify .env for the Ptylon fork (copy to .env at repo root).
# Non-secret local test token — MUST match agent-hosts.local.json auth_token_ref.
WEB_CONSOLE_ADMIN_TOKEN=local-verify-token
JWT_SECRET=local-verify-jwt-secret-change-me

# Ports (defaults).
WS_PORT=8791
NEXT_PUBLIC_WS_PORT=8791

# Workspace roots — the daemon jails sessions here; JOBS_ROOT must live under FILE_ACCESS_ROOT.
# For local verification, point these at a scratch dir you own.
WORKSPACE_ROOT=/tmp/ptylon-verify/workspace
FILE_ACCESS_ROOT=/tmp/ptylon-verify/workspace
ALLOWED_CWD_ROOT=/tmp/ptylon-verify/workspace
NEXT_PUBLIC_WORKSPACE_ROOT=/tmp/ptylon-verify/workspace
JOBS_ROOT=/tmp/ptylon-verify/workspace/.agent-jobs

# Engine startup delay (ms) before injecting the task prompt.
ENGINE_STARTUP_MS=1500
